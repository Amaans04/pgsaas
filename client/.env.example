# ============================================
# CLIENT — React + Vite
# Paste this as /client/.env.example
# Commit this to GitHub — no real values here
# ============================================

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Backend API — MUST include https:// (production example below)
VITE_SERVER_URL=https://pgsaas.vercel.app

# ImageKit keys live in server/.env.local — upload auth returns publicKey automatically.
# Optional client fallback only:
# VITE_IMAGEKIT_PUBLIC_KEY=
