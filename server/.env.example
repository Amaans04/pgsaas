# ============================================
# SERVER — Next.js API
# Paste this as /server/.env.example
# Commit this to GitHub — no real values here
# ============================================

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

ALLOWED_ORIGIN=http://localhost:5173

# JWT — generate with: openssl rand -base64 48
JWT_SECRET=
JWT_REFRESH_SECRET=

# ImageKit — document storage
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# Razorpay — get test keys from https://dashboard.razorpay.com/app/keys
# Leave empty in local dev to use simulated payments (dev mode)
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=
SMTP_EMAIL=
SMTP_PASSWORD=
