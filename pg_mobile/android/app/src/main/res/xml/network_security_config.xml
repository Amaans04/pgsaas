<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Release builds: HTTPS only. Debug manifest enables cleartext for local dev. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
